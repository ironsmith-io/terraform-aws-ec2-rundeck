# Required
key_pair_name = "my-keypair"
subnet_id     = "subnet-xxxxxxxx"

# Network Access (required - no defaults for security)
ip_allow_ssh   = ["0.0.0.0/0"] # Restrict to your admin CIDR in production
ip_allow_https = ["0.0.0.0/0"] # Restrict as needed

# Instance Configuration
# aws_region           = "us-west-2"    # Default
# instance_type        = "c5.large"     # Default
# root_volume_size     = 10             # GB, minimum for Rocky Linux
create_spot_instance = false            # Spot instances for cost savings (evaluation only)

# Access Methods
enable_ssh = true  # SSH access (set false for SSM-only)
enable_ssm = true  # AWS Systems Manager Session Manager

# Monitoring & Logging
enable_cloudwatch_logs = true # CloudWatch Logs + metrics (365-day retention)

# Security Alarms (requires enable_cloudwatch_logs = true)
enable_security_alarms = true              # CloudWatch alarms for AIDE, SSH, fail2ban, disk, CPU
create_sns_topic       = true              # Create SNS topic for alarm notifications
alarm_email            = "alerts@example.com" # Email for alarm notifications

# Session & Compliance Settings
# rundeck_session_timeout   = 30           # Session timeout in minutes (5-480, default 30 for HIPAA/PCI)
# enable_plugin_repository  = false        # Online plugin repo (default false for compliance)

# Data Protection
enable_ebs_snapshots = true # Automated daily EBS snapshots via DLM

# Encryption (optional - CloudWatch Logs uses AWS internal encryption by default)
# cloudwatch_kms_key_id = "arn:aws:kms:us-west-2:123456789012:key/12345678-1234-1234-1234-123456789012"

# Secure Credential Storage (recommended for production)
rundeck_admin_password_ssm_path = "/rundeck/admin-password" # SSM Parameter Store path

# Extra commands appended to cloud-init (runs after all services are started)
# user_data_extra = <<-EOT
#   dnf install -y git
#   echo "Custom setup complete"
# EOT
