.envrc
*.pem
.iron

# Local archive (internal docs not for git)
archive/

# IDE
.idea/
.vscode/

# AI assistant
CLAUDE.md

# OS files
.DS_Store

# Compliance scan reports
*-report.html
*-report.txt
